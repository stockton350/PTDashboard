{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://compasselt.io/schemas/lesson/v1",
  "title": "ELT Lesson",
  "description": "Schema for a single ELT lesson. Designed to drive three output renderers: (1) classroom presentation tool — teacher-controlled, sequential, with teacher notes and answer reveals; (2) mobile student practice app — interactive activities with per-option feedback and explanations; (3) printable worksheet generator — editable content, configurable layout, optional answer key.",
  "type": "object",
  "required": ["id", "schema_version", "metadata", "course", "sections", "activities"],
  "properties": {

    "id": {
      "type": "string",
      "description": "Unique lesson identifier, e.g. 'spark2-u2-l1'"
    },

    "schema_version": {
      "type": "string",
      "description": "Schema version this document conforms to",
      "pattern": "^\\d+\\.\\d+$"
    },

    "metadata": {
      "type": "object",
      "required": ["title", "unit_number", "lesson_number", "cefr_level", "age_group", "target_language", "learning_objectives"],
      "properties": {
        "title": { "type": "string" },
        "unit_number": { "type": "integer", "minimum": 1 },
        "lesson_number": { "type": "integer", "minimum": 1 },
        "unit_title": { "type": "string" },
        "cefr_level": {
          "type": "string",
          "enum": ["Pre-A1", "A1", "A2", "B1", "B2", "C1", "C2"]
        },
        "age_group": {
          "type": "string",
          "enum": ["very_young_learners", "young_learners", "teens", "young_adults", "adults"]
        },
        "target_language": { "type": "string", "description": "BCP 47 language tag, e.g. 'en'" },
        "duration_minutes": { "type": "integer" },
        "learning_objectives": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What students will be able to do after this lesson"
        },
        "key_vocabulary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "key_grammar": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["reading", "writing", "listening", "speaking", "grammar", "vocabulary", "phonics"]
          }
        },
        "page_range": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2,
          "description": "First and last page numbers from the printed textbook"
        },
        "topic_tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "course": {
      "type": "object",
      "required": ["name", "publisher", "series", "level"],
      "properties": {
        "name": { "type": "string", "description": "Full course name, e.g. 'Spark! Level 2'" },
        "publisher": { "type": "string" },
        "series": { "type": "string" },
        "level": { "type": "string", "description": "Publisher level label, e.g. 'Level 2' or 'B1–B2'" },
        "isbn": { "type": "string" },
        "edition": { "type": "string" }
      }
    },

    "sections": {
      "type": "array",
      "description": "Ordered list of content sections within the lesson (maps to named parts of the textbook page)",
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "activity_ids"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "warmup", "vocabulary", "reading", "dialogue", "grammar",
              "phonics", "listening", "speaking", "writing", "project",
              "values", "critical_thinking", "real_world_document", "review"
            ]
          },
          "title": { "type": "string" },
          "label": {
            "type": "string",
            "description": "Short display label shown in classroom/app section header, e.g. 'A VOCABULARY'"
          },
          "page_number": { "type": "integer" },
          "activity_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "content": {
            "type": "object",
            "description": "Section-level content not attached to a specific activity (e.g. a reading passage, dialogue, grammar rule)",
            "properties": {
              "text": {
                "type": "string",
                "description": "Full prose text (reading passage, grammar explanation, etc.)"
              },
              "pull_quote": { "type": "string" },
              "grammar_rule": {
                "type": "object",
                "properties": {
                  "structure": { "type": "string", "description": "e.g. 'HAVE/HAS + past participle'" },
                  "use": { "type": "string" },
                  "notes": { "type": "array", "items": { "type": "string" } },
                  "examples": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "sentence": { "type": "string" },
                        "highlight": { "type": "string" },
                        "polarity": { "type": "string", "enum": ["positive", "negative", "question"] },
                        "translation": { "type": "string" }
                      }
                    }
                  },
                  "comparison_table": {
                    "type": "array",
                    "description": "Rows for a grammar comparison table (e.g. present perfect vs simple past)",
                    "items": {
                      "type": "object",
                      "properties": {
                        "form_a": { "type": "string" },
                        "form_b": { "type": "string" },
                        "example_a": { "type": "string" },
                        "example_b": { "type": "string" },
                        "use_a": { "type": "string" },
                        "use_b": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "dialogue_lines": {
                "type": "array",
                "description": "Lines of a scripted dialogue",
                "items": {
                  "type": "object",
                  "required": ["speaker", "text"],
                  "properties": {
                    "speaker": { "type": "string" },
                    "speaker_role": { "type": "string", "description": "e.g. 'doctor', 'patient'" },
                    "text": { "type": "string" },
                    "audio": { "$ref": "#/definitions/audio_ref" }
                  }
                }
              },
              "real_world_document": {
                "type": "object",
                "description": "A real-world literacy item such as a prescription label, form, or sign",
                "properties": {
                  "document_type": { "type": "string", "description": "e.g. 'prescription_label', 'form', 'sign'" },
                  "title": { "type": "string" },
                  "fields": {
                    "type": "array",
                    "description": "Labelled fields on the document",
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": { "type": "string" },
                        "value": { "type": "string" },
                        "is_student_fill": { "type": "boolean" }
                      }
                    }
                  },
                  "warnings": { "type": "array", "items": { "type": "string" } },
                  "raw_text": { "type": "string", "description": "Full label text as it appears" }
                }
              },
              "image": { "$ref": "#/definitions/image_ref" },
              "audio": { "$ref": "#/definitions/audio_ref" }
            }
          }
        }
      }
    },

    "activities": {
      "type": "array",
      "description": "All interactive activities in the lesson",
      "items": { "$ref": "#/definitions/activity" }
    }
  },

  "definitions": {

    "image_ref": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "alt_text": { "type": "string" },
        "description": { "type": "string", "description": "Semantic description — renderers may substitute other images" },
        "credit": { "type": "string" },
        "local_path": { "type": "string" }
      }
    },

    "audio_ref": {
      "type": "object",
      "properties": {
        "track_id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "transcript": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "feedback_pair": {
      "type": "object",
      "properties": {
        "correct": { "type": "string", "description": "Shown when the student gets it right" },
        "incorrect": { "type": "string", "description": "Shown when the student gets it wrong" }
      }
    },

    "classroom_config": {
      "type": "object",
      "description": "Controls how the activity appears in the teacher-controlled classroom presentation tool",
      "properties": {
        "include": { "type": "boolean", "default": true },
        "display_mode": {
          "type": "string",
          "enum": ["full_activity", "item_by_item", "present_then_reveal", "teacher_led_only"],
          "description": "full_activity: show all items at once; item_by_item: advance through items manually; present_then_reveal: show question, then click to reveal answer; teacher_led_only: slide shown but no student interaction expected"
        },
        "teacher_notes": {
          "type": "string",
          "description": "Guidance visible only to teacher in the presentation tool"
        },
        "answer_reveal": {
          "type": "boolean",
          "default": true,
          "description": "Whether the teacher can reveal answers on screen"
        },
        "estimated_time_minutes": { "type": "integer" },
        "slide_title": { "type": "string" }
      }
    },

    "worksheet_config": {
      "type": "object",
      "description": "Controls how the activity is rendered in the printable worksheet generator",
      "properties": {
        "include": { "type": "boolean", "default": true },
        "editable": {
          "type": "boolean",
          "description": "If true, teachers can modify the items in the worksheet generator"
        },
        "format": {
          "type": "string",
          "enum": ["fill_blank", "multiple_choice", "matching_columns", "true_false", "open_ended", "table", "unscramble"],
          "description": "Default print format. Teachers may be able to switch this."
        },
        "print_instruction": {
          "type": "string",
          "description": "Instruction text for the printed worksheet (may differ from interactive instruction)"
        },
        "include_answer_key": { "type": "boolean", "default": false },
        "points_per_item": { "type": "number" }
      }
    },

    "app_config": {
      "type": "object",
      "description": "Controls how the activity appears in the mobile student practice app",
      "properties": {
        "include": { "type": "boolean", "default": true },
        "points": { "type": "integer", "description": "Points awarded for completing this activity" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "allow_hint": { "type": "boolean", "default": false },
        "feedback_mode": {
          "type": "string",
          "enum": ["immediate", "end_of_activity"],
          "default": "immediate"
        },
        "attempts_allowed": { "type": "integer", "description": "How many tries before answer is revealed. null = unlimited" }
      }
    },

    "activity": {
      "type": "object",
      "required": ["id", "number", "section_id", "type", "instruction", "items", "classroom", "worksheet", "app"],
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "integer", "description": "Printed activity number on the page" },
        "section_id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "vocabulary_presentation",
            "multiple_choice",
            "fill_in_blank",
            "matching",
            "ordering",
            "ranking",
            "speaking_prompt",
            "writing_prompt",
            "drawing",
            "phonics_drill",
            "grammar_presentation",
            "listening_task",
            "reading_comprehension",
            "dialogue_comprehension",
            "role_play"
          ]
        },
        "instruction": { "type": "string", "description": "The printed instruction line students see" },
        "sub_instruction": { "type": "string" },
        "icon": { "type": "string", "description": "Emoji or icon code for the activity type (🔊, ✏️, 💬 etc.)" },
        "image": { "$ref": "#/definitions/image_ref" },
        "audio": { "$ref": "#/definitions/audio_ref" },
        "items": {
          "type": "array",
          "description": "Individual questions or tasks within this activity",
          "items": { "$ref": "#/definitions/activity_item" }
        },
        "classroom": { "$ref": "#/definitions/classroom_config" },
        "worksheet": { "$ref": "#/definitions/worksheet_config" },
        "app": { "$ref": "#/definitions/app_config" }
      }
    },

    "activity_item": {
      "description": "A single question or task. The shape varies by activity type — use the 'type' discriminator.",
      "oneOf": [
        { "$ref": "#/definitions/items/vocabulary_item" },
        { "$ref": "#/definitions/items/multiple_choice_item" },
        { "$ref": "#/definitions/items/fill_blank_item" },
        { "$ref": "#/definitions/items/matching_pair" },
        { "$ref": "#/definitions/items/rank_option" },
        { "$ref": "#/definitions/items/order_item" },
        { "$ref": "#/definitions/items/speaking_item" },
        { "$ref": "#/definitions/items/writing_item" },
        { "$ref": "#/definitions/items/drawing_item" },
        { "$ref": "#/definitions/items/phonics_word" },
        { "$ref": "#/definitions/items/grammar_example" },
        { "$ref": "#/definitions/items/listening_row" },
        { "$ref": "#/definitions/items/comprehension_question" }
      ]
    },

    "items": {

      "vocabulary_item": {
        "type": "object",
        "required": ["id", "type", "word"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["vocabulary"] },
          "number": { "type": "integer" },
          "word": { "type": "string" },
          "part_of_speech": { "type": "string" },
          "definition": { "type": "string" },
          "translation": { "type": "string" },
          "example_sentence": { "type": "string" },
          "emoji": { "type": "string" },
          "image": { "$ref": "#/definitions/image_ref" },
          "audio": { "$ref": "#/definitions/audio_ref" },
          "collocation_partners": {
            "type": "array",
            "items": { "type": "string" },
            "description": "For collocation-based vocabulary (e.g. Life 2e style)"
          },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "multiple_choice_item": {
        "type": "object",
        "required": ["id", "type", "question", "options", "correct_option_id"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["multiple_choice"] },
          "number": { "type": "integer" },
          "question": { "type": "string" },
          "image": { "$ref": "#/definitions/image_ref" },
          "options": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["id", "text"],
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" },
                "image": { "$ref": "#/definitions/image_ref" },
                "feedback": { "$ref": "#/definitions/feedback_pair" }
              }
            }
          },
          "correct_option_id": { "type": "string" },
          "hint": { "type": "string" },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "fill_blank_item": {
        "type": "object",
        "required": ["id", "type", "template", "blanks"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["fill_blank"] },
          "number": { "type": "integer" },
          "template": {
            "type": "string",
            "description": "Full sentence with {{blank}} markers, e.g. 'It {{0}} a lion.'"
          },
          "display_prefix": { "type": "string", "description": "Optional label shown before the blank (e.g. an emoji)" },
          "blanks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "position", "accepted_answers", "display_answer"],
              "properties": {
                "id": { "type": "string" },
                "position": { "type": "integer" },
                "accepted_answers": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "All acceptable spellings/forms"
                },
                "display_answer": { "type": "string", "description": "Canonical answer shown in answer key" },
                "feedback": { "$ref": "#/definitions/feedback_pair" },
                "hint": { "type": "string" }
              }
            }
          },
          "word_bank": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional word bank shown to students — includes distractors"
          },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "matching_pair": {
        "type": "object",
        "required": ["id", "type", "left", "right"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["matching"] },
          "number": { "type": "integer" },
          "left": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "emoji": { "type": "string" },
              "image": { "$ref": "#/definitions/image_ref" }
            }
          },
          "right": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "definition": { "type": "string" },
              "image": { "$ref": "#/definitions/image_ref" }
            }
          },
          "feedback": { "$ref": "#/definitions/feedback_pair" },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "rank_option": {
        "type": "object",
        "required": ["id", "type", "text"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["ranking"] },
          "number": { "type": "integer" },
          "text": { "type": "string" },
          "suggested_rank": {
            "type": "integer",
            "description": "Editorial suggested rank (not a 'correct' answer). Used for teacher notes."
          },
          "rationale": {
            "type": "string",
            "description": "Teacher-facing explanation for this item's suggested rank"
          },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "order_item": {
        "type": "object",
        "required": ["id", "type", "text", "correct_position"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["ordering"] },
          "text": { "type": "string" },
          "correct_position": { "type": "integer", "minimum": 1 },
          "feedback": { "$ref": "#/definitions/feedback_pair" }
        }
      },

      "speaking_item": {
        "type": "object",
        "required": ["id", "type", "prompt"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["speaking"] },
          "prompt": { "type": "string" },
          "sub_prompts": { "type": "array", "items": { "type": "string" } },
          "interaction_pattern": {
            "type": "string",
            "enum": ["pair_work", "group_work", "whole_class", "individual"],
            "default": "pair_work"
          },
          "model_dialogue": {
            "type": "array",
            "description": "Example exchange shown as a model",
            "items": {
              "type": "object",
              "properties": {
                "speaker_label": { "type": "string" },
                "text": { "type": "string" }
              }
            }
          },
          "useful_language": {
            "type": "array",
            "items": { "type": "string" }
          },
          "self_assessment_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "writing_item": {
        "type": "object",
        "required": ["id", "type", "prompt"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["writing"] },
          "prompt": { "type": "string" },
          "line_count": { "type": "integer" },
          "word_limit_min": { "type": "integer" },
          "word_limit_max": { "type": "integer" },
          "model_answer": { "type": "string" },
          "scaffolding": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Sentence starters or frames"
          },
          "editable": { "type": "boolean", "default": true }
        }
      },

      "drawing_item": {
        "type": "object",
        "required": ["id", "type", "instruction"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["drawing"] },
          "instruction": { "type": "string" },
          "writing_prompts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "template": { "type": "string", "description": "Sentence starter, e.g. 'It is a ___'" },
                "line_count": { "type": "integer", "default": 1 }
              }
            }
          }
        }
      },

      "phonics_word": {
        "type": "object",
        "required": ["id", "type", "word", "target_phoneme"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["phonics"] },
          "word": { "type": "string" },
          "target_phoneme": { "type": "string", "description": "IPA symbol, e.g. '/æ/'" },
          "highlight_grapheme": { "type": "string", "description": "Which letter(s) to highlight, e.g. 'a'" },
          "audio": { "$ref": "#/definitions/audio_ref" }
        }
      },

      "grammar_example": {
        "type": "object",
        "required": ["id", "type", "sentence"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["grammar_example"] },
          "sentence": { "type": "string" },
          "polarity": { "type": "string", "enum": ["positive", "negative", "question"] },
          "highlight": {
            "type": "string",
            "description": "Substring to highlight (the target form)"
          },
          "translation": { "type": "string" },
          "note": { "type": "string" }
        }
      },

      "listening_row": {
        "type": "object",
        "required": ["id", "type", "row_label"],
        "description": "One row in a listening completion table",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["listening_row"] },
          "row_label": { "type": "string", "description": "e.g. speaker name 'Maria'" },
          "columns": {
            "type": "array",
            "description": "Column definitions with optional correct answers",
            "items": {
              "type": "object",
              "properties": {
                "column_id": { "type": "string" },
                "label": { "type": "string" },
                "answer": { "type": "string" },
                "is_student_fill": { "type": "boolean", "default": true }
              }
            }
          }
        }
      },

      "comprehension_question": {
        "type": "object",
        "required": ["id", "type", "question"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["comprehension"] },
          "number": { "type": "integer" },
          "question": { "type": "string" },
          "answer_type": {
            "type": "string",
            "enum": ["short_answer", "true_false", "multiple_choice"],
            "default": "short_answer"
          },
          "model_answer": { "type": "string" },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" },
                "feedback": { "$ref": "#/definitions/feedback_pair" }
              }
            }
          },
          "correct_option_id": { "type": "string" },
          "hint": { "type": "string" },
          "editable": { "type": "boolean", "default": true }
        }
      }
    }
  }
}
