    {
      "id": "dialogue",
      "type": "dialogue",
      "label": "B DIALOGUE",
      "title": "At the Doctor's Office",
      "page_number": 45,
      "activity_ids": [
        "act-2",
        "act-3"
      ],
      "content": {
        "dialogue_lines": [
          {
            "speaker": "DR. MILLER",
            "speaker_role": "doctor",
            "text": "Good morning. What seems to be the problem today?"
          },
          {
            "speaker": "PATIENT",
            "speaker_role": "patient",
            "text": "Hi, Doctor. I've had a headache for three days, and I feel very tired."
          },
          {
            "speaker": "DR. MILLER",
            "speaker_role": "doctor",
            "text": "I see. Do you have any other symptoms?"
          },
          {
            "speaker": "PATIENT",
            "speaker_role": "patient",
            "text": "Yes, I also have a sore throat and a slight fever."
          },
          {
            "speaker": "DR. MILLER",
            "speaker_role": "doctor",
            "text": "Let me take a look. Are you taking any medication at the moment?"
          },
          {
            "speaker": "PATIENT",
            "speaker_role": "patient",
            "text": "I took some aspirin, but it didn't really help."
          },
          {
            "speaker": "DR. MILLER",
            "speaker_role": "doctor",
            "text": "OK. I'm going to write you a prescription. You should rest and drink plenty of water."
          },
          {
            "speaker": "PATIENT",
            "speaker_role": "patient",
            "text": "Should I go to work tomorrow?"
          },
          {
            "speaker": "DR. MILLER",
            "speaker_role": "doctor",
            "text": "You shouldn't go to work for at least two days. Rest is very important."
          },
          {
            "speaker": "PATIENT",
            "speaker_role": "patient",
            "text": "Should I come back if I don't feel better?"
          },
          {
            "speaker": "DR. MILLER",
            "speaker_role": "doctor",
            "text": "Yes, you should call the office and make another appointment if your symptoms continue."
          }
        ]
      }
    },
    {
      "id": "grammar",
      "type": "grammar",
      "label": "C GRAMMAR FOCUS",
      "title": "Should / Shouldn't",
      "page_number": 46,
      "activity_ids": [
        "act-4",
        "act-5"
      ],
      "content": {
        "grammar_rule": {
          "structure": "should / shouldn't + base verb",
          "use": "giving and asking for advice",
          "notes": [
            "should does not change with he/she/it — no -s",
            "Use the base form of the verb after should/shouldn't"
          ],
          "examples": [
            {
              "sentence": "You should rest and drink plenty of water.",
              "polarity": "positive",
              "highlight": "should rest"
            },
            {
              "sentence": "You shouldn't go to work for at least two days.",
              "polarity": "negative",
              "highlight": "shouldn't go"
            },
            {
              "sentence": "Should I go to work tomorrow?",
              "polarity": "question",
              "highlight": "Should I go"
            },
            {
              "sentence": "You should call the office and make another appointment.",
              "polarity": "positive",
              "highlight": "should call"
            }
          ],
          "comparison_table": [
            {
              "form_a": "should",
              "form_b": "positive advice",
              "example_a": "You should rest.",
              "example_b": "She should see a doctor.",
              "use_a": "Recommending an action",
              "use_b": "Applies to all subjects — no -s"
            },
            {
              "form_a": "shouldn't",
              "form_b": "negative advice",
              "example_a": "You shouldn't go to work.",
              "example_b": "He shouldn't eat too much sugar.",
              "use_a": "Advising against an action",
              "use_b": "Short form of should not"
            },
            {
              "form_a": "Should...?",
              "form_b": "question / asking for advice",
              "example_a": "Should I come back?",
              "example_b": "Should she make an appointment?",
              "use_a": "Requesting advice or a recommendation",
              "use_b": "Invert subject and should to form a question"
            }
          ]
        }
      }
    },
