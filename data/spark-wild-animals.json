    "duration_minutes": 45,
    "learning_objectives": [
      "Name 6 wild animals in English",
      "Use 'It's a...' and 'It has...' to describe animals",
      "Recognise and produce the short /æ/ vowel sound",
      "Ask and answer 'What's this?' with a partner"
    ],
    "key_vocabulary": ["lion", "elephant", "giraffe", "parrot", "frog", "shark"],
    "key_grammar": ["It's a [noun].", "It has [feature]."],
    "skills": ["vocabulary", "listening", "speaking", "writing", "phonics"],
    "page_range": [20, 23],
    "topic_tags": ["animals", "wild animals", "nature", "describing"]
  },

