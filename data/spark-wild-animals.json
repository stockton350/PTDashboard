    {
      "id": "grammar",
      "type": "grammar",
      "title": "Language Focus",
      "label": "B GRAMMAR",
      "page_number": 22,
      "activity_ids": ["act-4", "act-5"],
      "content": {
        "grammar_rule": {
          "structure": "It's a + noun / It has + noun phrase",
          "use": "Use 'It's a' to identify an animal. Use 'It has' to describe a feature of the animal.",
          "notes": [
            "Use 'It's a' before an animal name (noun).",
            "Use 'It has' before a description of a feature (noun phrase)."
          ],
          "examples": [
            {
              "sentence": "It's a lion.",
              "highlight": "It's a",
              "polarity": "positive"
            },
            {
              "sentence": "It has a big mane.",
              "highlight": "It has",
              "polarity": "positive"
            },
            {
              "sentence": "It's a shark.",
              "highlight": "It's a",
              "polarity": "positive"
            },
            {
              "sentence": "It has sharp teeth.",
              "highlight": "It has",
              "polarity": "positive"
            }
          ]
        }
      }
    },
